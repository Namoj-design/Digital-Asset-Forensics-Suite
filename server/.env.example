# Forensics API (server/)
# Use a dedicated DB so this schema does not clash with legacy backend tables.
FORENSICS_DATABASE_URL=postgres://localhost:5432/dafs_forensics
# Or set DATABASE_URL (shared with other apps) — FORENSICS_DATABASE_URL wins.

FORENSICS_PORT=4000
# Optional override for file storage (default: server/uploads)
# FORENSICS_UPLOAD_DIR=/var/lib/dafs/uploads

NODE_ENV=development
LOG_LEVEL=info

# Login: in development defaults to password "password" if unset.
# In production, DEMO_PASSWORD is required.
DEMO_PASSWORD=password
